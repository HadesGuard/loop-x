# Global project
COMPOSE_PROJECT_NAME=loopx

# Domain (replace with your real domain)
SERVER_NAME_WEB=example.com

# Frontend
# Used at build-time for Next.js to call the backend via the same domain
# The Nginx config proxies "/api/*" to the backend.
NEXT_PUBLIC_API_URL=https://${SERVER_NAME_WEB}/api

# Postgres
POSTGRES_USER=loop_user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=loop_db

# Backend
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://${SERVER_NAME_WEB}

# Database URL used by backend/worker containers (overrides localhost)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# JWT (generate secure values and set in real .env)
JWT_SECRET=REPLACE_ME
JWT_REFRESH_SECRET=REPLACE_ME
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Shelby network (production values required for mainnet)
SHELBY_NETWORK=mainnet
SHELBY_API_KEY=REPLACE_ME
SHELBY_SERVICE_ACCOUNT_PRIVATE_KEY=REPLACE_ME
SHELBY_SERVICE_ACCOUNT_ADDRESS=REPLACE_ME

# Shelby delivery (CDN/gateway)
# Recommended: configure a CDN in front of Shelby RPC and set SHELBY_CDN_BASE_URL.
# For Bunny CDN, use your pull zone hostname (no trailing slash), e.g.:
#   SHELBY_CDN_BASE_URL=https://loopx-shelby.b-cdn.net
SHELBY_CDN_BASE_URL=
# Fallback: set a direct gateway base if no CDN is available (e.g., Geomi RPC):
#   SHELBY_GATEWAY_BASE_URL=https://api.shelbynet.shelby.xyz/shelby
SHELBY_GATEWAY_BASE_URL=

# Video processing
FFMPEG_PATH=/usr/bin/ffmpeg
VIDEO_MAX_SIZE=524288000
VIDEO_ALLOWED_FORMATS=mp4,mov,avi

# Logging
LOG_LEVEL=info

# Note: Never commit a real .env with secrets; use this file as a template only.
