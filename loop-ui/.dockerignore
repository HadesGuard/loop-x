# Exclude local-only artifacts from Docker build context
node_modules
.next/cache
.next/static/chunks/cache
# Vercel/Next artifacts
.vercel
# VCS and OS files
.git
.gitignore
.DS_Store
# Env files (never bake secrets into images)
.env
.env.local
.env.*.local
# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
