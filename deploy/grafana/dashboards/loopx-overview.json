{
  "schemaVersion": 38,
  "title": "LoopX Overview",
  "uid": "loopx-overview",
  "version": 1,
  "timezone": "browser",
  "tags": ["loopx", "backend"],
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "Request Rate (req/s)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m]))",
          "legendFormat": "{{status_code}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Rate (5xx req/s)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~\\"5..\\"}[5m]))",
          "legendFormat": "5xx",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency p50/p95/p99 (s)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Video Queue Length",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "bullmq_queue_jobs{queue=\\"video-processing\\",status=\\"waiting\\"}",
          "legendFormat": "waiting",
          "refId": "A"
        },
        {
          "expr": "bullmq_queue_jobs{queue=\\"video-processing\\",status=\\"active\\"}",
          "legendFormat": "active",
          "refId": "B"
        },
        {
          "expr": "bullmq_queue_jobs{queue=\\"video-processing\\",status=\\"failed\\"}",
          "legendFormat": "failed",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Job Duration (seconds)",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "bullmq_job_duration_seconds{queue=\\"video-processing\\"}",
          "legendFormat": "p50/p95/p99",
          "refId": "A"
        }
      ]
    }
  ]
}

