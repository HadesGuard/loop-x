# Server Configuration
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://loop_user:loop_password@localhost:5432/loop_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT Authentication
# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-random-generate-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-random-generate-this
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Shelby Network
SHELBY_API_KEY=your-shelby-api-key
SHELBY_SERVICE_ACCOUNT_PRIVATE_KEY=0x...your-service-account-private-key
SHELBY_SERVICE_ACCOUNT_ADDRESS=0x...your-service-account-address

# Video Processing
FFMPEG_PATH=/usr/bin/ffmpeg
VIDEO_MAX_SIZE=524288000
VIDEO_ALLOWED_FORMATS=mp4,mov,avi

# Logging
LOG_LEVEL=info

# Redis (for BullMQ video processing queue)
# These are used separately from REDIS_URL by the queue system
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Docker Compose (defaults if not set)
POSTGRES_USER=loop_user
POSTGRES_PASSWORD=loop_password
POSTGRES_DB=loop_db
